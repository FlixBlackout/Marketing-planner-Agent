.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
*.md
docs/

# Tests
tests/
test_*.py
*_test.py
pytest.ini
.pytest_cache/
.coverage

# CI/CD
.github/
.gitlab-ci.yml
Jenkinsfile

# Environment
.env
.env.*
!.env.example

# Logs
*.log
logs/

