# Environment Variables for Marketing Planning Assistant
# Copy this file to .env and fill in your API keys

# ============================================================================
# LLM API KEYS (Optional - App works without these in Simple mode)
# ============================================================================

# For Gemini AI (Recommended):
# Get your free API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyB8nxiVWjbay-UAEeCl5KeZsONlNdb7kDQ

# For OpenAI GPT (Alternative):
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# Preferred LLM Model (if using AI-powered mode)
# Options: gemini-pro, gpt-4, gpt-3.5-turbo
LLM_MODEL=gemini-pro

# Temperature (0.0 to 1.0)
# Higher = more creative, Lower = more deterministic
TEMPERATURE=0.7

# Maximum tokens for AI responses
MAX_TOKENS=2000

# ============================================================================
# NOTES:
# ============================================================================
# - The application works WITHOUT any API keys using Simple Planner mode
# - API keys are only needed for AI-powered goal interpretation
# - Gemini API is currently free with generous limits
# - Never commit this file with real keys to version control!
# ============================================================================
